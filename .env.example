# 环境变量说明（复制到 Render 的 Environment Variables 中）

# ===================== 必填 =====================
# 微信公众平台「开发 → 基本配置」中自己填写的 Token（随便一个字符串，如 MyBuddyToken123）
WECHAT_TOKEN=你自己设置的Token

# ===================== AI（二选一）=====================

# 方案A：OpenAI 或兼容 OpenAI 格式的 API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# 如果用国内中转或其他兼容接口，填下面这行；用官方 OpenAI 则不需要
# OPENAI_BASE_URL=https://你的中转地址/v1
# OPENAI_MODEL=gpt-4o-mini

# 方案B：腾讯混元（与方案A二选一，同时填写会优先用方案A）
# HUNYUAN_SECRET_ID=AKIDxxxxxxxxxx
# HUNYUAN_SECRET_KEY=xxxxxxxxxx
